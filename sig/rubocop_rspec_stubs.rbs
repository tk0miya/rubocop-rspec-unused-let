# Hand-written stubs for rubocop-rspec, which ships no RBS signatures and is
# not available in the RBS collection. Only the surface used by this gem's cop
# is declared.

module RuboCop
  module Cop
    module RSpec
      class Base
        def cop_config: () -> Hash[String, untyped]

        def processed_source: () -> RuboCop::AST::ProcessedSource

        def add_offense: (untyped node, ?message: String) -> void
                       | (untyped node, ?message: String) { (RuboCop::Cop::Corrector) -> void } -> void

        def range_by_whole_lines: (Parser::Source::Range range, ?include_final_newline: bool) -> Parser::Source::Range

        def self.def_node_matcher: (Symbol, String) -> void

        def self.def_node_search: (Symbol, String) -> void
      end
    end
  end

  module AST
    # The collection's RBS omits `file_path`; declare only what this gem uses.
    class ProcessedSource
      def file_path: () -> String?
    end
  end

  module RSpec
    # Node-pattern DSL matchers (`rspec?`, `ExampleGroups.all`, ...) mixed into
    # objects that inspect RSpec ASTs. Only its presence is needed here.
    module Language
    end

    class ExampleGroup
      def initialize: (RuboCop::AST::Node node) -> void

      def lets: () -> Array[RuboCop::AST::Node]

      def subjects: () -> Array[RuboCop::AST::Node]

      def hooks: () -> Array[RuboCop::RSpec::Hook]
    end

    class Hook
      def to_node: () -> RuboCop::AST::Node
    end
  end
end
